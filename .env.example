# Copy this file to .env and adjust for your local environment.
# The .env file is never committed.

# --- PostgreSQL (docker-compose) ---
POSTGRES_DB=finora
POSTGRES_USER=finora
POSTGRES_PASSWORD=finora_dev
# Host port for the dockerized PostgreSQL (5433 avoids clashing with a native install).
POSTGRES_PORT=5433

# --- Backend (apps/api) ---
# Spring reads these when set; defaults in application.yml match docker-compose defaults.
FINORA_DB_URL=jdbc:postgresql://localhost:5433/finora
FINORA_DB_USER=finora
FINORA_DB_PASSWORD=finora_dev
# Comma-separated origins allowed by CORS (development frontend).
FINORA_CORS_ALLOWED_ORIGINS=http://localhost:5173
# Authenticated session lifetime (Spring duration format, e.g. 12h, 30m).
FINORA_SESSION_TIMEOUT=12h
# Set true when serving over HTTPS so the session cookie is Secure.
FINORA_COOKIE_SECURE=false
# One-time secret enabling the legacy v1 data claim flow. Leave unset to keep
# the flow disabled. Never commit a real value.
# FINORA_LEGACY_CLAIM_TOKEN=

# --- Frontend (apps/web) ---
# Base URL of the Finora API used by the web app in development.
VITE_API_BASE_URL=http://localhost:8080/api
