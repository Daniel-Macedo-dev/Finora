# Copy this file to .env and adjust for your local environment.
# The .env file is never committed.

# --- PostgreSQL (docker-compose) ---
POSTGRES_DB=finora
POSTGRES_USER=finora
POSTGRES_PASSWORD=finora_dev
POSTGRES_PORT=5432

# --- Backend (apps/api) ---
# Spring reads these when set; defaults in application.yml match docker-compose defaults.
FINORA_DB_URL=jdbc:postgresql://localhost:5432/finora
FINORA_DB_USER=finora
FINORA_DB_PASSWORD=finora_dev
# Comma-separated origins allowed by CORS (development frontend).
FINORA_CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Frontend (apps/web) ---
# Base URL of the Finora API used by the web app in development.
VITE_API_BASE_URL=http://localhost:8080/api
